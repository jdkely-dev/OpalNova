<Window x:Class="JewelleryBusinessManager.Views.PaymentCollectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OPALNOVA Payment &amp; Collection" Height="760" Width="1180" WindowStartupLocation="CenterOwner"
        Background="#040813">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#0D1422" />
        <SolidColorBrush x:Key="SoftPanelBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="BorderBrush" Color="#334155" />
        <SolidColorBrush x:Key="TextBrush" Color="#EFEAE0" />
        <SolidColorBrush x:Key="MutedBrush" Color="#D8CEBE" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#60A5FA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Background" Value="#020617" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="4" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Padding" Value="8" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Payment &amp; Collection Workflow" FontSize="24" FontWeight="Bold" />
                    <TextBlock Text="Record deposits/progress payments, prepare pickup or shipping, create receipts and complete jobs." Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBox x:Name="SearchBox" Width="260" TextChanged="SearchBox_TextChanged" ToolTip="Search by job, customer or job code" />
                    <ComboBox x:Name="FilterCombo" Width="180" SelectionChanged="FilterCombo_SelectionChanged">
                        <ComboBoxItem Content="Active handover jobs" IsSelected="True" />
                        <ComboBoxItem Content="Ready for collection" />
                        <ComboBoxItem Content="Ready to ship" />
                        <ComboBoxItem Content="Balances owing" />
                        <ComboBoxItem Content="Completed" />
                        <ComboBoxItem Content="All jobs" />
                    </ComboBox>
                    <Button Content="Refresh" Click="Refresh_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Jobs" FontSize="18" FontWeight="SemiBold" Margin="4,0,0,8" />
                    <ListBox x:Name="JobsList" SelectionChanged="JobsList_SelectionChanged" Background="#040813" BorderBrush="{StaticResource BorderBrush}" Foreground="#EFEAE0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8" Margin="3" BorderBrush="#334155" BorderThickness="0,0,0,1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding TitleLine}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding CustomerLine}" Foreground="#D8CEBE" />
                                        <TextBlock Text="{Binding StatusLine}" Foreground="#D8CEBE" />
                                        <TextBlock Text="{Binding MoneyLine}" Foreground="#B8892E" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="SelectedJobTitle" Text="Select a job" FontSize="22" FontWeight="Bold" />
                        <TextBlock x:Name="SelectedJobDetails" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,12" TextWrapping="Wrap" />

                        <UniformGrid Columns="4" Margin="0,4,0,10">
                            <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="10" Padding="10" Margin="4">
                                <StackPanel><TextBlock Text="Total" Foreground="{StaticResource MutedBrush}" /><TextBlock x:Name="TotalAmountText" FontSize="20" FontWeight="Bold" /></StackPanel>
                            </Border>
                            <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="10" Padding="10" Margin="4">
                                <StackPanel><TextBlock Text="Paid" Foreground="{StaticResource MutedBrush}" /><TextBlock x:Name="PaidAmountText" FontSize="20" FontWeight="Bold" /></StackPanel>
                            </Border>
                            <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="10" Padding="10" Margin="4">
                                <StackPanel><TextBlock Text="Balance" Foreground="{StaticResource MutedBrush}" /><TextBlock x:Name="BalanceAmountText" FontSize="20" FontWeight="Bold" /></StackPanel>
                            </Border>
                            <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="10" Padding="10" Margin="4">
                                <StackPanel><TextBlock Text="Status" Foreground="{StaticResource MutedBrush}" /><TextBlock x:Name="StatusText" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" /></StackPanel>
                            </Border>
                        </UniformGrid>

                        <GroupBox Header="Record Payment">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Amount" Grid.Row="0" Grid.Column="0" Margin="6" />
                                <TextBlock Text="Method" Grid.Row="0" Grid.Column="1" Margin="6" />
                                <TextBlock Text="Date" Grid.Row="0" Grid.Column="2" Margin="6" />
                                <TextBlock Text="Reference / notes" Grid.Row="0" Grid.Column="3" Margin="6" />
                                <TextBox x:Name="PaymentAmountBox" Grid.Row="1" Grid.Column="0" />
                                <ComboBox x:Name="PaymentMethodCombo" Grid.Row="1" Grid.Column="1" />
                                <DatePicker x:Name="PaymentDatePicker" Grid.Row="1" Grid.Column="2" />
                                <TextBox x:Name="PaymentReferenceBox" Grid.Row="1" Grid.Column="3" />
                            </Grid>
                        </GroupBox>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Record Payment" Click="RecordPayment_Click" />
                            <Button Content="Generate Invoice / Receipt" Click="GenerateInvoice_Click" />
                            <Button Content="Create Pickup Reminder" Click="CreatePickupReminder_Click" />
                        </StackPanel>

                        <GroupBox Header="Handover Actions">
                            <WrapPanel>
                                <Button Content="Mark Ready For Collection" Click="MarkReadyForCollection_Click" />
                                <Button Content="Mark Ready To Ship" Click="MarkReadyToShip_Click" />
                                <Button Content="Create Sale From Job" Click="CreateSale_Click" />
                                <Button Content="Mark Collected / Complete" Click="MarkCollected_Click" />
                                <Button Content="Mark Shipped / Complete" Click="MarkShipped_Click" />
                            </WrapPanel>
                        </GroupBox>

                        <GroupBox Header="Payment History">
                            <DataGrid x:Name="PaymentsGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="170" Background="#040813" Foreground="#EFEAE0" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding PaymentDate, StringFormat=d}" Width="110" />
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=C}" Width="110" />
                                    <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="120" />
                                    <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="180" />
                                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Header="Collection / Shipping Notes">
                            <TextBox x:Name="HandoverNotesBox" Height="86" AcceptsReturn="True" TextWrapping="Wrap" />
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
            <TextBlock x:Name="StatusMessageText" Foreground="{StaticResource MutedBrush}" Text="Ready." />
        </Border>
    </Grid>
</Window>
