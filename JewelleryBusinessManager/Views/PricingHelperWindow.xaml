<Window x:Class="JewelleryBusinessManager.Views.PricingHelperWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pricing Helper" Height="720" Width="780" WindowStartupLocation="CenterOwner">
    <DockPanel Background="{StaticResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Top" Padding="16" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Pricing Helper" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Estimate material, labour, total cost, retail price and margin before creating or editing stock." Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Padding="12" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Calculate" Click="Calculate_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Close" Click="Close_Click" />
            </StackPanel>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                    <TextBlock x:Name="MetalPriceSummaryText" TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" />
                </Border>
                <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Inputs" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="4,0,4,12" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Metal" Margin="4" VerticalAlignment="Center" />
                        <ComboBox x:Name="MetalBox" Grid.Row="1" Grid.Column="1" Margin="4">
                            <ComboBoxItem Content="Sterling Silver" IsSelected="True" />
                            <ComboBoxItem Content="9ct Gold" />
                            <ComboBoxItem Content="14ct Gold" />
                            <ComboBoxItem Content="18ct Gold" />
                            <ComboBoxItem Content="Platinum" />
                            <ComboBoxItem Content="Palladium" />
                        </ComboBox>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Metal grams" Margin="4" VerticalAlignment="Center" />
                        <TextBox x:Name="MetalGramsBox" Grid.Row="2" Grid.Column="1" Margin="4" Text="0" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Stone cost" Margin="4" VerticalAlignment="Center" />
                        <TextBox x:Name="StoneCostBox" Grid.Row="3" Grid.Column="1" Margin="4" Text="0" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Other material / consumables" Margin="4" VerticalAlignment="Center" />
                        <TextBox x:Name="OtherCostBox" Grid.Row="4" Grid.Column="1" Margin="4" Text="0" />
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Labour hours" Margin="4" VerticalAlignment="Center" />
                        <TextBox x:Name="LabourHoursBox" Grid.Row="5" Grid.Column="1" Margin="4" Text="0" />
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Target profit margin %" Margin="4" VerticalAlignment="Center" />
                        <TextBox x:Name="TargetMarginBox" Grid.Row="6" Grid.Column="1" Margin="4" />
                    </Grid>
                </Border>
                <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Estimate" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock x:Name="ResultText" TextWrapping="Wrap" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,10,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
