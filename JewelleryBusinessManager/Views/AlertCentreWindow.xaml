<Window x:Class="JewelleryBusinessManager.Views.AlertCentreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OPALNOVA Alert Centre" Height="780" Width="1280" WindowStartupLocation="CenterOwner"
        Background="#040813">
    <Grid x:Name="AlertRoot" Margin="0">
        <Grid.Resources>
            <SolidColorBrush x:Key="AlertPanelBrush" Color="#0D1422" />
            <SolidColorBrush x:Key="AlertSoftBrush" Color="#162033" />
            <SolidColorBrush x:Key="AlertBorderBrush" Color="#29384F" />
            <SolidColorBrush x:Key="AlertTextBrush" Color="#EFEAE0" />
            <SolidColorBrush x:Key="AlertMutedBrush" Color="#B8AD9E" />
            <SolidColorBrush x:Key="AlertGoldBrush" Color="#CDA24A" />
            <SolidColorBrush x:Key="AlertGoldHoverBrush" Color="#B8892E" />

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource AlertTextBrush}" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="Margin" Value="4" />
                <Setter Property="Padding" Value="11,7" />
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Background" Value="#1B2942" />
                <Setter Property="Foreground" Value="{StaticResource AlertTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AlertBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
            </Style>
            <Style x:Key="PrimaryAlertButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{StaticResource AlertGoldBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AlertGoldHoverBrush}" />
                <Setter Property="Foreground" Value="#040813" />
                <Setter Property="FontWeight" Value="Bold" />
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Margin" Value="4" />
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Background" Value="#040813" />
                <Setter Property="Foreground" Value="{StaticResource AlertTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AlertBorderBrush}" />
            </Style>
            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                <Setter Property="Margin" Value="4" />
                <Setter Property="Padding" Value="7,5" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="Background" Value="#040813" />
                <Setter Property="Foreground" Value="{StaticResource AlertTextBrush}" />
            </Style>
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="#040813" />
                <Setter Property="Foreground" Value="{StaticResource AlertTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AlertBorderBrush}" />
                <Setter Property="GridLinesVisibility" Value="Horizontal" />
                <Setter Property="HorizontalGridLinesBrush" Value="#29384F" />
                <Setter Property="RowBackground" Value="#08101D" />
                <Setter Property="AlternatingRowBackground" Value="#0D1422" />
                <Setter Property="HeadersVisibility" Value="Column" />
                <Setter Property="AutoGenerateColumns" Value="False" />
                <Setter Property="IsReadOnly" Value="True" />
                <Setter Property="CanUserAddRows" Value="False" />
                <Setter Property="SelectionMode" Value="Single" />
                <Setter Property="SelectionUnit" Value="FullRow" />
            </Style>
            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#162033" />
                <Setter Property="Foreground" Value="{StaticResource AlertTextBrush}" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource AlertPanelBrush}" BorderBrush="{StaticResource AlertBorderBrush}" BorderThickness="0,0,0,1" Padding="8,5">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Alert Centre" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0" />
                    <TextBlock Text="Next actions across quotes, jobs, payments, diamonds, inventory and follow-ups" Foreground="{StaticResource AlertMutedBrush}" VerticalAlignment="Center" />
                </StackPanel>
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBox x:Name="SearchBox" Width="260" TextChanged="SearchBox_TextChanged" ToolTip="Search title, detail, risk, area or next action" />
                    <ComboBox x:Name="FilterCombo" Width="190" SelectionChanged="FilterCombo_SelectionChanged" SelectedIndex="0">
                        <ComboBoxItem Content="Action needed" />
                        <ComboBoxItem Content="Urgent" />
                        <ComboBoxItem Content="High" />
                        <ComboBoxItem Content="Quotes" />
                        <ComboBoxItem Content="Production" />
                        <ComboBoxItem Content="Payments" />
                        <ComboBoxItem Content="Diamonds" />
                        <ComboBoxItem Content="Inventory" />
                        <ComboBoxItem Content="Follow-ups" />
                        <ComboBoxItem Content="All alerts" />
                    </ComboBox>
                    <Button Content="Refresh" Click="Refresh_Click" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,6,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="0" Columns="6" Margin="0,0,0,8">
                <Border Background="{StaticResource AlertSoftBrush}" BorderBrush="{StaticResource AlertBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="3">
                    <StackPanel>
                        <TextBlock Text="Action Needed" Foreground="{StaticResource AlertMutedBrush}" />
                        <TextBlock x:Name="ActionNeededCountText" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AlertGoldBrush}" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource AlertSoftBrush}" BorderBrush="{StaticResource AlertBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="3">
                    <StackPanel>
                        <TextBlock Text="Urgent" Foreground="{StaticResource AlertMutedBrush}" />
                        <TextBlock x:Name="UrgentCountText" FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource AlertSoftBrush}" BorderBrush="{StaticResource AlertBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="3">
                    <StackPanel>
                        <TextBlock Text="Quotes" Foreground="{StaticResource AlertMutedBrush}" />
                        <TextBlock x:Name="QuoteCountText" FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource AlertSoftBrush}" BorderBrush="{StaticResource AlertBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="3">
                    <StackPanel>
                        <TextBlock Text="Production" Foreground="{StaticResource AlertMutedBrush}" />
                        <TextBlock x:Name="ProductionCountText" FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource AlertSoftBrush}" BorderBrush="{StaticResource AlertBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="3">
                    <StackPanel>
                        <TextBlock Text="Payments" Foreground="{StaticResource AlertMutedBrush}" />
                        <TextBlock x:Name="PaymentCountText" FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource AlertSoftBrush}" BorderBrush="{StaticResource AlertBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="3">
                    <StackPanel>
                        <TextBlock Text="Follow-Ups" Foreground="{StaticResource AlertMutedBrush}" />
                        <TextBlock x:Name="FollowUpCountText" FontSize="22" FontWeight="Bold" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.25*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource AlertPanelBrush}" BorderBrush="{StaticResource AlertBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="8">
                    <DataGrid x:Name="AlertsGrid" SelectionChanged="AlertsGrid_SelectionChanged" MouseDoubleClick="AlertsGrid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Priority" Binding="{Binding PriorityLabel}" Width="105" />
                            <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="110" />
                            <DataGridTextColumn Header="Alert" Binding="{Binding Title}" Width="2*" />
                            <DataGridTextColumn Header="Next Action" Binding="{Binding SuggestedAction}" Width="2.2*" />
                            <DataGridTextColumn Header="Due" Binding="{Binding DueLine}" Width="130" />
                            <DataGridTextColumn Header="Value" Binding="{Binding ValueLine}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Column="2" Background="{StaticResource AlertPanelBrush}" BorderBrush="{StaticResource AlertBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock x:Name="SelectedTitleText" Text="Select an alert" FontSize="22" FontWeight="Bold" TextWrapping="Wrap" />
                            <TextBlock x:Name="SelectedSubtitleText" Text="Choose a row to see the recommended next action." Foreground="{StaticResource AlertMutedBrush}" Margin="0,4,0,12" TextWrapping="Wrap" />

                            <Border Background="#040813" BorderBrush="{StaticResource AlertBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Recommended action" Foreground="{StaticResource AlertGoldBrush}" FontWeight="Bold" />
                                    <TextBlock x:Name="SuggestedActionText" Text="No alert selected." FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    <TextBlock x:Name="RiskText" Foreground="#FB7185" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Details" Foreground="{StaticResource AlertGoldBrush}" FontWeight="Bold" Margin="0,2,0,4" />
                            <TextBlock x:Name="DetailText" Foreground="{StaticResource AlertMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />

                            <WrapPanel Margin="0,8,0,0">
                                <Button x:Name="OpenSelectedButton" Content="Open Next Step" Click="OpenSelected_Click" Style="{StaticResource PrimaryAlertButtonStyle}" />
                                <Button Content="Open Project Hub" Click="OpenProjectHub_Click" />
                                <Button Content="Open Tasks" Click="OpenTasks_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <DockPanel Grid.Row="2" LastChildFill="True" Margin="0,4,0,0">
            <Button DockPanel.Dock="Right" Content="Close" Click="Close_Click" />
            <TextBlock x:Name="StatusText" Foreground="{StaticResource AlertMutedBrush}" VerticalAlignment="Center" Text="Alert Centre ready." />
        </DockPanel>
    </Grid>
</Window>
