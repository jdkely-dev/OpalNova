<Window x:Class="JewelleryBusinessManager.Views.MarketSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Record Market Sale" Height="560" Width="760" WindowStartupLocation="CenterOwner">
    <DockPanel Background="{StaticResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Top" Padding="16" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Record Market Sale" FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Text="Mark a market stock item as sold, create a sale record and update the jewellery item status." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        <ScrollViewer Padding="18">
            <StackPanel>
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Market Stock Item" FontWeight="SemiBold" FontSize="16" />
                        <ComboBox x:Name="MarketStockBox" DisplayMemberPath="Display" SelectedValuePath="Id" Margin="0,8,0,4" SelectionChanged="MarketStockBox_SelectionChanged" />
                        <TextBlock x:Name="StockInfoText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Sale Price" FontWeight="SemiBold" />
                            <TextBox x:Name="SalePriceBox" Margin="0,6,0,12" />
                            <TextBlock Text="Payment Method" FontWeight="SemiBold" />
                            <ComboBox x:Name="PaymentMethodBox" Margin="0,6,0,12" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Customer (optional)" FontWeight="SemiBold" />
                            <ComboBox x:Name="CustomerBox" DisplayMemberPath="Display" SelectedValuePath="Id" Margin="0,6,0,12" />
                            <TextBlock Text="Notes" FontWeight="SemiBold" />
                            <TextBox x:Name="NotesBox" Margin="0,6,0,0" MinHeight="80" AcceptsReturn="True" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                    <TextBlock Text="This will create a Sale record, mark the market stock as sold, mark the linked jewellery item as Sold and update the market reconciliation figures." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save Market Sale" Click="Save_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource ToolbarButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
