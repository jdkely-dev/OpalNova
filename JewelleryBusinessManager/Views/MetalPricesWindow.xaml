<Window x:Class="JewelleryBusinessManager.Views.MetalPricesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Metal Prices" Height="690" Width="760" WindowStartupLocation="CenterOwner">
    <DockPanel Background="{StaticResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Top" Padding="16" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Metal Prices" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Set manual precious-metal prices or refresh live spot prices with your own API key." Foreground="{StaticResource MutedTextBrush}" />
            </StackPanel>
        </Border>
        <Border DockPanel.Dock="Bottom" Padding="12" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Refresh Live" Click="RefreshLive_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Save" Click="Save_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Close" Click="Close_Click" />
            </StackPanel>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"><Run Text="Live refresh now supports GoldAPI.net and GoldAPI.io keys. Choose the provider that issued your key. Prices are stored locally in business settings. Manual values are still supported, so the app remains usable offline at markets." /></TextBlock>
                </Border>

                <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Live Price Settings" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="4,0,4,12" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="API Provider" Margin="4" VerticalAlignment="Center" />
                        <ComboBox x:Name="ProviderBox" Grid.Row="1" Grid.Column="1" Margin="4" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Currency" Margin="4" VerticalAlignment="Center" />
                        <ComboBox x:Name="CurrencyBox" Grid.Row="2" Grid.Column="1" Margin="4" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="API Key" Margin="4" VerticalAlignment="Center" />
                        <PasswordBox x:Name="ApiKeyBox" Grid.Row="3" Grid.Column="1" Margin="4" />
                    </Grid>
                </Border>

                <Border Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="190" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Prices Per Gram" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="4,0,4,12" />
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Gold / gram" Margin="4" VerticalAlignment="Center" />
                        <TextBox x:Name="GoldBox" Grid.Row="1" Grid.Column="1" Margin="4" />
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Silver / gram" Margin="4" VerticalAlignment="Center" />
                        <TextBox x:Name="SilverBox" Grid.Row="2" Grid.Column="1" Margin="4" />
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Platinum / gram" Margin="4" VerticalAlignment="Center" />
                        <TextBox x:Name="PlatinumBox" Grid.Row="3" Grid.Column="1" Margin="4" />
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Palladium / gram" Margin="4" VerticalAlignment="Center" />
                        <TextBox x:Name="PalladiumBox" Grid.Row="4" Grid.Column="1" Margin="4" />
                    </Grid>
                </Border>

                <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Status" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock x:Name="LastUpdatedText" TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,6,0,0" />
                        <TextBlock x:Name="SourceNoteText" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
