<Window x:Class="JewelleryBusinessManager.Views.ProductionBoardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OPALNOVA - Production Board" Height="820" Width="1500"
        MinHeight="650" MinWidth="1050" WindowStartupLocation="CenterOwner"
        Background="#0B1220">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#EFEAE0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#EFEAE0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#EFEAE0"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Padding" Value="9,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Visual Production Board" Foreground="#EFEAE0" FontSize="27" FontWeight="SemiBold"/>
                <TextBlock Text="Move workshop jobs through quoting, approval, bench work, finishing and collection." Foreground="#B8AD9E" Margin="0,5,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Refresh" Click="Refresh_Click"/>
                <Button Content="Move Back" Click="MoveBack_Click"/>
                <Button Content="Move Forward" Click="MoveForward_Click"/>
                <Button Content="Stage Checklist" Click="StageChecklist_Click"/>
                <Button Content="Complete Selected" Click="CompleteSelected_Click"/>
                <Button Content="Edit Selected Job" Click="EditSelected_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="#0D1422" BorderBrush="#243244" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,16,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" ToolTip="Search job code, title, customer or quote" TextChanged="Filter_Changed" Margin="0,0,12,0"/>
                <CheckBox x:Name="OverdueOnlyCheck" Grid.Column="1" Content="Overdue only" Foreground="#E2D8C8" VerticalAlignment="Center" Margin="6,0,14,0" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <CheckBox x:Name="ActiveOnlyCheck" Grid.Column="2" Content="Active only" Foreground="#E2D8C8" VerticalAlignment="Center" Margin="6,0,14,0" IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <ComboBox x:Name="SortCombo" Grid.Column="3" Width="170" SelectionChanged="Filter_Changed">
                    <ComboBoxItem Content="Due date" IsSelected="True"/>
                    <ComboBoxItem Content="Last updated"/>
                    <ComboBoxItem Content="Customer"/>
                </ComboBox>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel x:Name="BoardPanel" Orientation="Horizontal"/>
        </ScrollViewer>

        <Border Grid.Row="3" Background="#0D1422" BorderBrush="#243244" BorderThickness="1" CornerRadius="9" Padding="12" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="SelectionText" Text="Select a job card to see its next action." Foreground="#D8CEBE" TextWrapping="Wrap"/>
                <TextBlock x:Name="SummaryText" Grid.Column="1" Foreground="#B8AD9E" Margin="18,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
