<Window x:Class="JewelleryBusinessManager.Views.StoneWorkflowWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stone Workflow" Height="430" Width="540" WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Border Margin="18" Padding="18" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                <TextBlock Text="Stone Workflow" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock x:Name="StoneSummaryText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Save Stage" Click="Save_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource ToolbarButtonStyle}" />
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Workflow Stage" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" />
                <ComboBox x:Name="StageComboBox" Margin="0,6,0,14" Height="34">
                    <ComboBoxItem Content="Rough" />
                    <ComboBoxItem Content="Loose" />
                    <ComboBoxItem Content="Cutting" />
                    <ComboBoxItem Content="Polished" />
                    <ComboBoxItem Content="Selected For Design" />
                    <ComboBoxItem Content="Assigned To Jewellery" />
                    <ComboBoxItem Content="Set In Jewellery" />
                    <ComboBoxItem Content="Reserved" />
                    <ComboBoxItem Content="Sold" />
                </ComboBox>

                <TextBlock Text="Workflow Notes" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" />
                <TextBox x:Name="NotesTextBox" Margin="0,6,0,12" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12">
                    <TextBlock Text="Tip: Use this to track rough opal through cutting, polishing, design selection, setting, reservation and sale. Each save appends a timestamped note to the stone record." TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" />
                </Border>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
