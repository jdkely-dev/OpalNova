<Window x:Class="JewelleryBusinessManager.Views.MarketReconcileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Reconcile Market" Height="640" Width="820" WindowStartupLocation="CenterOwner">
    <DockPanel Background="{StaticResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Top" Padding="16" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Reconcile Market Event" FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Text="Enter takings and costs, then update packed/sold/returned counts and market profit estimate." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        <ScrollViewer Padding="18">
            <StackPanel>
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Market Event" FontWeight="SemiBold" FontSize="16" />
                        <ComboBox x:Name="MarketBox" DisplayMemberPath="Display" SelectedValuePath="Id" Margin="0,8,0,4" SelectionChanged="MarketBox_SelectionChanged" />
                        <TextBlock x:Name="MarketInfoText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                        <TextBlock x:Name="ReconciliationGuidanceText" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Opening Float" FontWeight="SemiBold" />
                            <TextBox x:Name="OpeningFloatBox" Margin="0,6,0,12" />
                            <TextBlock Text="Cash Sales" FontWeight="SemiBold" />
                            <TextBox x:Name="CashSalesBox" Margin="0,6,0,12" TextChanged="MoneyBox_TextChanged" />
                            <TextBlock Text="Card Sales" FontWeight="SemiBold" />
                            <TextBox x:Name="CardSalesBox" Margin="0,6,0,0" TextChanged="MoneyBox_TextChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                            <TextBlock Text="Other Sales" FontWeight="SemiBold" />
                            <TextBox x:Name="OtherSalesBox" Margin="0,6,0,12" TextChanged="MoneyBox_TextChanged" />
                            <TextBlock Text="Stall Fee" FontWeight="SemiBold" />
                            <TextBox x:Name="StallFeeBox" Margin="0,6,0,12" />
                            <TextBlock Text="Travel Cost" FontWeight="SemiBold" />
                            <TextBox x:Name="TravelCostBox" Margin="0,6,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="Display Cost" FontWeight="SemiBold" />
                            <TextBox x:Name="DisplayCostBox" Margin="0,6,0,12" />
                            <TextBlock Text="Other Costs" FontWeight="SemiBold" />
                            <TextBox x:Name="OtherCostsBox" Margin="0,6,0,12" />
                            <TextBlock Text="Notes" FontWeight="SemiBold" />
                            <TextBox x:Name="NotesBox" Margin="0,6,0,0" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                    <TextBlock Text="Tip: Market stock sales recorded through Market Sale will already update sale totals. Use this screen to enter cash/card totals, float, stall fee, travel and display costs." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save &amp; Reconcile" Click="Save_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource ToolbarButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
