<Window x:Class="JewelleryBusinessManager.Views.BulkStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bulk Status Update" Width="500" Height="360" WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}" Foreground="{StaticResource PrimaryTextBrush}">
    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Margin="16" Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock Text="Bulk Status Update" FontSize="26" FontWeight="Bold" />
                <TextBlock x:Name="SubtitleText" Text="Choose a new status for selected records." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,6,0,18" />
            </StackPanel>

            <Border Grid.Row="1" Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="18">
                <StackPanel>
                    <TextBlock Text="NEW STATUS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,6" />
                    <ComboBox x:Name="StatusCombo" MinHeight="36" Tag="Choose a status" />
                    <TextBlock Text="This changes only the selected records in the active table. Use reports first if you need to audit a large cleanup list." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,16,0,0" />
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0" />
                <Button Content="Apply Status" Click="Apply_Click" Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
