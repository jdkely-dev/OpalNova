<Window x:Class="JewelleryBusinessManager.Views.DiamondSupplierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nivoda Diamond Supplier" Height="780" Width="1180" WindowStartupLocation="CenterOwner">
    <DockPanel Background="{StaticResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Top" Padding="16" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Diamond Supplier API - Nivoda" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Search external diamond stock using your Nivoda username/password. Results are external supply options, not owned OPALNOVA inventory." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="12" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" DockPanel.Dock="Left" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" TextWrapping="Wrap" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Use Default Endpoints" Click="UseDefaultNivodaEndpoints_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Reset the API URLs only. Credentials must be entered by the user." />
                    <Button Content="Open GraphiQL" Click="OpenGraphiQl_Click" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="Test Connection" Click="TestConnection_Click" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="Staging Handoff" Click="StagingHandoff_Click" Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="Save Settings" Click="SaveSettings_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Close" Click="Close_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="API Settings" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="4,0,4,10" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Environment" Margin="4" VerticalAlignment="Center" />
                    <TextBox x:Name="EnvironmentBox" Grid.Row="1" Grid.Column="1" Margin="4" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Review URL" Margin="4" VerticalAlignment="Center" />
                    <TextBox x:Name="ReviewUrlBox" Grid.Row="1" Grid.Column="3" Margin="4" ToolTip="Optional external staging link, such as a private build share or hosted handoff page." />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Endpoint" Margin="4" VerticalAlignment="Center" />
                    <TextBox x:Name="EndpointBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="4" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Username" Margin="4" VerticalAlignment="Center" />
                    <TextBox x:Name="UsernameBox" Grid.Row="3" Grid.Column="1" Margin="4" />
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Password" Margin="4" VerticalAlignment="Center" />
                    <PasswordBox x:Name="PasswordBox" Grid.Row="3" Grid.Column="3" Margin="4" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="GraphiQL" Margin="4" VerticalAlignment="Center" />
                    <TextBox x:Name="GraphiQlBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" Margin="4" />
                    <TextBlock Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Margin="4,6,4,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Text="Enter your Nivoda credentials, then save settings and test the connection. The default endpoint button resets API URLs only and never fills a password." />
                    <TextBlock Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Margin="4,2,4,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Text="Use Staging Handoff to generate a non-secret report with endpoints, GraphiQL, auth/schema status and fields Nivoda needs to confirm for hold/order actions." />
                </Grid>
            </Border>

            <Border Grid.Row="1" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="9" Text="Search Filters" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="4,0,4,10" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Shape" Margin="4" VerticalAlignment="Center" />
                    <ComboBox x:Name="ShapeBox" Grid.Row="1" Grid.Column="1" Margin="4" Tag="Choose a shape" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Carat Min" Margin="4" VerticalAlignment="Center" />
                    <TextBox x:Name="MinCaratBox" Grid.Row="1" Grid.Column="3" Margin="4" />
                    <TextBlock Grid.Row="1" Grid.Column="4" Text="Carat Max" Margin="4" VerticalAlignment="Center" />
                    <TextBox x:Name="MaxCaratBox" Grid.Row="1" Grid.Column="5" Margin="4" />
                    <CheckBox x:Name="LabGrownCheck" Grid.Row="1" Grid.Column="6" Margin="4" VerticalAlignment="Center" Content="Lab-grown" />
                    <TextBlock Grid.Row="1" Grid.Column="7" Text="Labs" Margin="4" VerticalAlignment="Center" />
                    <DockPanel Grid.Row="1" Grid.Column="8" Margin="4">
                        <Button DockPanel.Dock="Right" Content="Search" Click="Search_Click" Style="{StaticResource AccentButtonStyle}" />
                        <TextBox x:Name="LabsBox" Margin="0,0,8,0" />
                    </DockPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="10">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Save Selected Result" Click="SaveSelected_Click" Style="{StaticResource AccentButtonStyle}" Margin="0,0,8,0" />
                                <Button Content="Saved Records" Click="OpenSavedRecords_Click" Style="{StaticResource ToolbarButtonStyle}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Search Results" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="Select a row, then click Save Selected Result." Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                            </StackPanel>
                        </DockPanel>
                        <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding SupplierDiamondId}" Width="120" />
                                <DataGridTextColumn Header="Shape" Binding="{Binding Shape}" Width="85" />
                                <DataGridTextColumn Header="ct" Binding="{Binding Carat}" Width="60" />
                                <DataGridTextColumn Header="Col" Binding="{Binding Color}" Width="55" />
                                <DataGridTextColumn Header="Clarity" Binding="{Binding Clarity}" Width="75" />
                                <DataGridTextColumn Header="Cut" Binding="{Binding Cut}" Width="75" />
                                <DataGridTextColumn Header="Lab" Binding="{Binding Lab}" Width="60" />
                                <DataGridTextColumn Header="Cert" Binding="{Binding CertificateNumber}" Width="100" />
                                <DataGridTextColumn Header="Supplier" Binding="{Binding SupplierPrice}" Width="80" />
                                <DataGridTextColumn Header="Retail Est." Binding="{Binding EstimatedRetailPrice}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
                <Border Grid.Column="2" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12">
                    <StackPanel>
                        <TextBlock Text="Selected Diamond Actions" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Save useful search results as external diamond records. They remain separate from owned stones until ordered/received." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,8,0,12" />
                        <TextBlock Text="Default currency" />
                        <TextBox x:Name="CurrencyBox" Margin="0,4,0,8" />
                        <TextBlock Text="Retail markup %" />
                        <TextBox x:Name="MarkupBox" Margin="0,4,0,12" />
                        <Button Content="Save Selected External Diamond" Click="SaveSelected_Click" Style="{StaticResource AccentButtonStyle}" Margin="0,0,0,8" />
                        <Button Content="Open Video" Click="OpenVideo_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,0,8" />
                        <Button Content="Copy Certificate Number" Click="CopyCert_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,0,8" />
                        <Button Content="Open Saved External Diamond Records" Click="OpenSavedRecords_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,0,16" />
                        <TextBlock Text="Important" FontWeight="SemiBold" />
                        <TextBlock Text="This integration searches supplier stock and stores useful results as external diamond records. Confirm supplier availability before promising a stone to a customer." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
