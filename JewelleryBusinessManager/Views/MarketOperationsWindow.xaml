<Window x:Class="JewelleryBusinessManager.Views.MarketOperationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Market Operations Studio" Height="880" Width="1440" WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}" UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource TopHeaderBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="22" Margin="0,0,0,16" Effect="{StaticResource CardShadowEffect}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Market Operations Studio" FontSize="30" FontWeight="Black" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="Run sales, packing, returns and a customer-facing checkout display from one dedicated market screen." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,5,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#172033" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="18" Padding="14,9" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="Operator Mode" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Background="#111827" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="14,9">
                        <TextBlock Text="Customer Display Ready" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="330" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,14,0">
                <StackPanel>
                    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,0,0,14" Effect="{StaticResource CardShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="1. Market Setup" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="Choose your event and customer display screen before selling." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />

                            <TextBlock Text="MARKET EVENT" Style="{StaticResource PillTextStyle}" />
                            <ComboBox x:Name="MarketBox" DisplayMemberPath="Name" SelectionChanged="MarketBox_SelectionChanged" Margin="0,7,0,12" Tag="Choose a market" />

                            <TextBlock Text="CUSTOMER DISPLAY SCREEN" Style="{StaticResource PillTextStyle}" />
                            <ComboBox x:Name="ScreenBox" Margin="0,7,0,10" Tag="Choose display screen" />
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Button Content="Open Display" Click="OpenCustomerDisplay_Click" Style="{StaticResource AccentButtonStyle}" />
                                <Button Grid.Column="2" Content="Clear" Click="ClearCustomerDisplay_Click" Style="{StaticResource ToolbarButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,0,0,14" Effect="{StaticResource CardShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="2. Checkout" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="Select stock from the table, check the price, preview for the customer, then record the sale." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />

                            <Border Background="#050914" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="SELECTED ITEM" Style="{StaticResource PillTextStyle}" />
                                    <TextBlock x:Name="SelectedItemText" Text="Select market stock on the right." Foreground="{StaticResource SecondaryTextBrush}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="SALE PRICE" Style="{StaticResource PillTextStyle}" />
                            <TextBox x:Name="SalePriceBox" Text="0.00" FontSize="28" FontWeight="Black" TextAlignment="Center" Margin="0,7,0,10" />
                            <TextBlock Text="PAYMENT METHOD" Style="{StaticResource PillTextStyle}" />
                            <ComboBox x:Name="PaymentBox" Margin="0,7,0,12" Tag="Choose payment method">
                                <ComboBoxItem Content="Card" IsSelected="True" />
                                <ComboBoxItem Content="Cash" />
                                <ComboBoxItem Content="Bank Transfer" />
                                <ComboBoxItem Content="Other" />
                            </ComboBox>

                            <Button Content="Preview On Customer Display" Click="PreviewSale_Click" Style="{StaticResource ToolbarButtonStyle}" />
                            <Button Content="Record Market Sale" Click="RecordSale_Click" Style="{StaticResource AccentButtonStyle}" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="18" Effect="{StaticResource CardShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="3. Quick Stock Actions" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="Use these during setup and pack-down." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />
                            <Button Content="Mark Selected Packed" Click="MarkPacked_Click" Style="{StaticResource ToolbarButtonStyle}" />
                            <Button Content="Return Selected To Stock" Click="ReturnToStock_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,8,0,0" />
                            <Button Content="Refresh Market Stock" Click="Refresh_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,8,0,0" />
                            <Border Background="#111827" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,14,0,0">
                                <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" Margin="0,0,14,0">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,0,0,12" Effect="{StaticResource CardShadowEffect}">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Market Stock Register" FontSize="24" FontWeight="Bold" />
                            <TextBlock x:Name="MarketSummaryText" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="#050914" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="10" VerticalAlignment="Center">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                                <TextBlock Text="Search" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox Grid.Column="1" x:Name="SearchBox" TextChanged="SearchBox_TextChanged" ToolTip="Search market stock" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="8" Effect="{StaticResource CardShadowEffect}">
                    <DataGrid x:Name="MarketStockGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="MarketStockGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding StockCode}" Width="120" />
                            <DataGridTextColumn Header="Item" Binding="{Binding ItemName}" Width="*" />
                            <DataGridTextColumn Header="Price" Binding="{Binding RetailPrice, StringFormat=C}" Width="110" />
                            <DataGridTextColumn Header="State" Binding="{Binding StateLine}" Width="110" />
                            <DataGridTextColumn Header="Packed" Binding="{Binding Packed}" Width="80" />
                            <DataGridTextColumn Header="Sold" Binding="{Binding SoldAtMarket}" Width="80" />
                            <DataGridTextColumn Header="Returned" Binding="{Binding ReturnedToStock}" Width="90" />
                            <DataGridTextColumn Header="Payment" Binding="{Binding PaymentMethod}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
                <Border Grid.Row="2" Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,12,0,0">
                    <TextBlock Text="Recommended workflow: pack stock before opening, preview for the customer, then record the sale through the shared market workflow so stock, sales and reconciliation stay aligned." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                </Border>
            </Grid>

            <Border Grid.Column="2" Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="18" Effect="{StaticResource CardShadowEffect}">
                <StackPanel>
                    <TextBlock Text="Live Customer Preview" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Use this as your operator-side preview before sending the item to the customer display." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />
                    <Border Background="#030712" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="22" Padding="20" Height="315">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Text="Customer Display" Foreground="{StaticResource AccentBrush}" FontSize="20" FontWeight="Black" TextAlignment="Center" />
                            <TextBlock Grid.Row="1" Text="Selected item and sale price will appear on the external display." Foreground="{StaticResource SecondaryTextBrush}" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="17" />
                            <TextBlock Grid.Row="2" Text="Thank you" Foreground="{StaticResource MutedTextBrush}" TextAlignment="Center" />
                        </Grid>
                    </Border>
                    <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Fast checks" Style="{StaticResource PillTextStyle}" />
                            <TextBlock Text="- Correct market selected" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,8,0,0" />
                            <TextBlock Text="- Customer display open" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,5,0,0" />
                            <TextBlock Text="- Price confirmed" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,5,0,0" />
                            <TextBlock Text="- Payment method selected" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
