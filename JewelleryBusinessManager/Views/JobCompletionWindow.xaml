<Window x:Class="JewelleryBusinessManager.Views.JobCompletionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OPALNOVA Job Completion Checklist" Height="760" Width="1180" WindowStartupLocation="CenterOwner"
        Background="#040813">
    <Window.Resources>
        <SolidColorBrush x:Key="CompletionPanelBrush" Color="#0D1422" />
        <SolidColorBrush x:Key="CompletionSoftBrush" Color="#162033" />
        <SolidColorBrush x:Key="CompletionBorderBrush" Color="#29384F" />
        <SolidColorBrush x:Key="CompletionTextBrush" Color="#EFEAE0" />
        <SolidColorBrush x:Key="CompletionMutedBrush" Color="#B8AD9E" />
        <SolidColorBrush x:Key="CompletionGoldBrush" Color="#CDA24A" />
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CompletionTextBrush}" />
        </Style>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Background" Value="#1B2942" />
            <Setter Property="Foreground" Value="{StaticResource CompletionTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CompletionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="PrimaryCompletionButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource CompletionGoldBrush}" />
            <Setter Property="Foreground" Value="#040813" />
            <Setter Property="BorderBrush" Value="#B8892E" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource CompletionTextBrush}" />
            <Setter Property="Margin" Value="0,5,0,5" />
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="#020617" />
            <Setter Property="Foreground" Value="{StaticResource CompletionTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CompletionBorderBrush}" />
            <Setter Property="Padding" Value="8,5" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#040813" />
            <Setter Property="Foreground" Value="{StaticResource CompletionTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CompletionBorderBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#29384F" />
            <Setter Property="RowBackground" Value="#08101D" />
            <Setter Property="AlternatingRowBackground" Value="#0D1422" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#162033" />
            <Setter Property="Foreground" Value="{StaticResource CompletionTextBrush}" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource CompletionPanelBrush}" BorderBrush="{StaticResource CompletionBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="JobTitleText" Text="Job completion" FontSize="24" FontWeight="Bold" />
                    <TextBlock x:Name="JobDetailText" Foreground="{StaticResource CompletionMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock x:Name="QuoteDetailText" Foreground="{StaticResource CompletionMutedBrush}" TextWrapping="Wrap" Margin="0,3,0,0" />
                </StackPanel>
                <UniformGrid Grid.Column="1" Columns="3" Margin="16,0,0,0">
                    <Border Background="{StaticResource CompletionSoftBrush}" BorderBrush="{StaticResource CompletionBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="4">
                        <StackPanel>
                            <TextBlock Text="Total" Foreground="{StaticResource CompletionMutedBrush}" />
                            <TextBlock x:Name="TotalText" FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource CompletionSoftBrush}" BorderBrush="{StaticResource CompletionBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="4">
                        <StackPanel>
                            <TextBlock Text="Paid" Foreground="{StaticResource CompletionMutedBrush}" />
                            <TextBlock x:Name="PaidText" FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource CompletionSoftBrush}" BorderBrush="{StaticResource CompletionBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="4">
                        <StackPanel>
                            <TextBlock Text="Balance" Foreground="{StaticResource CompletionMutedBrush}" />
                            <TextBlock x:Name="BalanceText" FontSize="18" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource CompletionPanelBrush}" BorderBrush="{StaticResource CompletionBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Reserved Materials" FontSize="18" FontWeight="SemiBold" Margin="2,0,0,8" />
                    <DataGrid x:Name="MaterialsGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding MaterialCode}" Width="110" />
                            <DataGridTextColumn Header="Material" Binding="{Binding MaterialName}" Width="2*" />
                            <DataGridTextColumn Header="Consume" Binding="{Binding QuantityLine}" Width="110" />
                            <DataGridTextColumn Header="On Hand" Binding="{Binding CurrentLine}" Width="120" />
                            <DataGridTextColumn Header="Status" Binding="{Binding ResultLine}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="2" Grid.Column="0" Background="{StaticResource CompletionPanelBrush}" BorderBrush="{StaticResource CompletionBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Reserved Stones" FontSize="18" FontWeight="SemiBold" Margin="2,0,0,8" />
                    <DataGrid x:Name="StonesGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding StoneCode}" Width="120" />
                            <DataGridTextColumn Header="Stone" Binding="{Binding Description}" Width="2*" />
                            <DataGridTextColumn Header="Current" Binding="{Binding CurrentStatus}" Width="140" />
                            <DataGridTextColumn Header="Reservation" Binding="{Binding ReservationStatus}" Width="130" />
                            <DataGridTextColumn Header="Result" Binding="{Binding ResultLine}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="2" Background="{StaticResource CompletionPanelBrush}" BorderBrush="{StaticResource CompletionBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="14">
                <StackPanel>
                    <TextBlock Text="Completion Actions" FontSize="19" FontWeight="Bold" />
                    <TextBlock x:Name="WarningText" Foreground="#FB7185" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,6,0,10" />
                    <CheckBox x:Name="ConsumeMaterialsCheck" Content="Consume reserved material quantities" IsChecked="True" />
                    <CheckBox x:Name="MarkStonesSetCheck" Content="Mark reserved stones as set in jewellery" IsChecked="True" />
                    <CheckBox x:Name="ReleaseReservationsCheck" Content="Release any unconsumed reservation lines" IsChecked="True" />
                    <CheckBox x:Name="AllowBalanceCheck" Content="Allow completion with outstanding balance" />
                    <CheckBox x:Name="AllowNegativeStockCheck" Content="Allow material stock to go below zero" />

                    <TextBlock Text="Completion note" Foreground="{StaticResource CompletionGoldBrush}" FontWeight="Bold" Margin="0,16,0,5" />
                    <TextBox x:Name="CompletionNoteBox" Height="130" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                    <Border Background="#040813" BorderBrush="{StaticResource CompletionBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,14,0,0">
                        <TextBlock x:Name="SummaryText" Foreground="{StaticResource CompletionMutedBrush}" TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <DockPanel Grid.Row="2" LastChildFill="True">
            <WrapPanel DockPanel.Dock="Right">
                <Button Content="Cancel" Click="Cancel_Click" />
                <Button Content="Complete Job" Click="CompleteJob_Click" Style="{StaticResource PrimaryCompletionButtonStyle}" />
            </WrapPanel>
            <TextBlock x:Name="StatusText" Foreground="{StaticResource CompletionMutedBrush}" VerticalAlignment="Center" Text="Review linked inventory before completing the job." />
        </DockPanel>
    </Grid>
</Window>
