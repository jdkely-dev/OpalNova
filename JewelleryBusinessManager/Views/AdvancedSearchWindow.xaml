<Window x:Class="JewelleryBusinessManager.Views.AdvancedSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Advanced Search &amp; Saved Views" Height="760" Width="1180" WindowStartupLocation="CenterOwner" UseLayoutRounding="True" SnapsToDevicePixels="True" TextOptions.TextRenderingMode="ClearType">
    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="18" Effect="{StaticResource CardShadowEffect}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Search &amp; Views" FontSize="28" FontWeight="Bold" />
                    <TextBlock Text="Search records and workflow actions, apply quick filters, then save useful views for daily work." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,5,0,18" />

                    <TextBlock Text="SECTION" Style="{StaticResource PillTextStyle}" Margin="0,0,0,5" />
                    <ComboBox x:Name="SectionCombo" Margin="0,0,0,12" Tag="Choose a section" />

                    <TextBlock Text="SEARCH TEXT" Style="{StaticResource PillTextStyle}" Margin="0,0,0,5" />
                    <TextBox x:Name="KeywordBox" Margin="0,0,0,12" ToolTip="Search text, codes, statuses, notes, visible field values and workflow actions." />

                    <TextBlock Text="QUICK FILTER" Style="{StaticResource PillTextStyle}" Margin="0,0,0,5" />
                    <ComboBox x:Name="FilterCombo" Margin="0,0,0,16" Tag="Choose a filter" />

                    <Button Content="Search Now" Click="Search_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,8" />
                    <Button Content="Open Selected Record" Click="OpenSelected_Click" Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,18" />

                    <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Saved Views" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Save searches such as Low Stock, Jobs Due Soon, At Market, Ready To List, or customer follow-ups." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,10" />
                            <TextBox x:Name="SavedViewNameBox" Margin="0,0,0,8" ToolTip="Name this saved search/filter view." />
                            <Button Content="Save Current View" Click="SaveView_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,10" />
                            <ComboBox x:Name="SavedViewsCombo" Margin="0,0,0,8" Tag="Choose a saved view" />
                            <Button Content="Apply Saved View" Click="ApplySavedView_Click" Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,8" />
                            <Button Content="Delete Saved View" Click="DeleteSavedView_Click" Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="StatusText" Text="Ready." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="2" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="16" Effect="{StaticResource CardShadowEffect}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Search Results" FontSize="22" FontWeight="Bold" />
                        <TextBlock x:Name="ResultSummaryText" Text="Run a search to see matching records and workflow actions." Foreground="{StaticResource MutedTextBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Close" Click="Close_Click" Style="{StaticResource ToolbarButtonStyle}" />
                    </Grid>
                </Border>
                <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" MouseDoubleClick="ResultsGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="150" />
                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="260" />
                        <DataGridTextColumn Header="Summary" Binding="{Binding Summary}" Width="*" />
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="70" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
