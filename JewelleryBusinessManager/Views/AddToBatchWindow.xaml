<Window x:Class="JewelleryBusinessManager.Views.AddToBatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add To Production Batch" Height="520" Width="620" WindowStartupLocation="CenterOwner">
    <DockPanel Background="{StaticResource AppBackgroundBrush}" Margin="0">
        <Border DockPanel.Dock="Top" Padding="16" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Add To Production Batch" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="SelectedRecordText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Batch" VerticalAlignment="Center" Margin="4" />
            <ComboBox x:Name="BatchCombo" Grid.Row="0" Grid.Column="1" Margin="4" DisplayMemberPath="Label" SelectedValuePath="Id" Tag="Choose a batch" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Item name" VerticalAlignment="Center" Margin="4" />
            <TextBox x:Name="ItemNameBox" Grid.Row="1" Grid.Column="1" Margin="4" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Item type" VerticalAlignment="Center" Margin="4" />
            <TextBox x:Name="ItemTypeBox" Grid.Row="2" Grid.Column="1" Margin="4" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Planned quantity" VerticalAlignment="Center" Margin="4" />
            <TextBox x:Name="PlannedQuantityBox" Grid.Row="3" Grid.Column="1" Margin="4" Text="1" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Estimated cost" VerticalAlignment="Center" Margin="4" />
            <TextBox x:Name="EstimatedCostBox" Grid.Row="4" Grid.Column="1" Margin="4" Text="0" />

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Estimated retail value" VerticalAlignment="Center" Margin="4" />
            <TextBox x:Name="EstimatedRetailBox" Grid.Row="5" Grid.Column="1" Margin="4" Text="0" />

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Notes" VerticalAlignment="Top" Margin="4" />
            <TextBox x:Name="NotesBox" Grid.Row="6" Grid.Column="1" Margin="4" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

            <StackPanel Grid.Row="7" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Add To Batch" Click="Add_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Cancel" Margin="8,0,0,0" Click="Cancel_Click" Style="{StaticResource ToolbarButtonStyle}" />
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
