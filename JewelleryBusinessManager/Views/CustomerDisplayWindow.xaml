<Window x:Class="JewelleryBusinessManager.Views.CustomerDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer Display" Height="720" Width="1100" WindowStartupLocation="Manual"
        Background="#020617" WindowStyle="SingleBorderWindow" UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Grid>
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.2" GradientOrigin="0.5,0.2" RadiusX="0.9" RadiusY="0.9">
                <GradientStop Color="#172033" Offset="0" />
                <GradientStop Color="#07111F" Offset="0.45" />
                <GradientStop Color="#020617" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>
        <Grid Margin="34">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Border Background="#111827" BorderBrush="#374151" BorderThickness="1" CornerRadius="28" Padding="24" Margin="0,0,0,28">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel HorizontalAlignment="Center" Grid.ColumnSpan="2">
                        <TextBlock x:Name="BusinessNameText" Text="OPALNOVA" Foreground="#CDA24A" FontSize="42" FontWeight="Black" TextAlignment="Center" />
                        <TextBlock Text="Market Checkout" Foreground="#D8CEBE" FontSize="19" TextAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="1" Background="#0B1220" BorderBrush="#41516A" BorderThickness="1" CornerRadius="36" Padding="46">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="8" Opacity="0.35" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <TextBlock x:Name="ItemNameText" Text="Select an item on the operator screen" Foreground="#EFEAE0" FontSize="48" FontWeight="Black" TextAlignment="Center" TextWrapping="Wrap" />
                    <Border Grid.Row="1" Background="#111827" BorderBrush="#29384F" BorderThickness="1" CornerRadius="24" Padding="28" Margin="0,36">
                        <TextBlock x:Name="ItemDetailsText" Text="The selected piece, price and checkout message will appear here for the customer." Foreground="#D8CEBE" FontSize="25" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL" Foreground="#B8AD9E" FontSize="18" FontWeight="Bold" TextAlignment="Center" />
                        <TextBlock x:Name="TotalText" Text="$0.00" Foreground="#CDA24A" FontSize="82" FontWeight="Black" TextAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="2" Background="#111827" BorderBrush="#29384F" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,28,0,0">
                <TextBlock x:Name="FooterText" Text="Thank you for supporting handmade jewellery." Foreground="#D8CEBE" FontSize="21" TextAlignment="Center" TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Grid>
</Window>
