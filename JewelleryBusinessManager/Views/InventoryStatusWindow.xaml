<Window x:Class="JewelleryBusinessManager.Views.InventoryStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Inventory Status" Height="420" Width="620" WindowStartupLocation="CenterOwner">
    <DockPanel Background="{StaticResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Top" Padding="16" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Change Inventory Status" FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Text="Quickly reserve, release, mark at market, sold, loose or set without opening the full edit form." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        <StackPanel Margin="18">
            <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock x:Name="RecordText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock x:Name="CurrentStatusText" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,12" />
                    <TextBlock x:Name="CurrentLifecycleText" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <TextBlock Text="New Status" FontWeight="SemiBold" />
                    <ComboBox x:Name="StatusBox" Margin="0,6,0,8" SelectionChanged="StatusBox_SelectionChanged" Tag="Choose a new status" />
                    <TextBlock x:Name="NewStatusLifecycleText" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <TextBlock Text="Notes" FontWeight="SemiBold" />
                    <TextBox x:Name="NotesBox" MinHeight="80" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="12" Margin="0,0,0,12">
                <TextBlock Text="Lifecycle tip: only use Sold or SetInJewellery when the item is no longer available. Use Reserved for customer commitments, AtMarket for packed stock, and NeedsPhotos before listing online." TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" />
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save Status" Click="Save_Click" Style="{StaticResource AccentButtonStyle}" />
                <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource ToolbarButtonStyle}" />
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
