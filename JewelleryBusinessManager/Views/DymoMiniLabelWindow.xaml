<Window x:Class="JewelleryBusinessManager.Views.DymoMiniLabelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mini Label Studio" Height="740" Width="1120" WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}" UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource TopHeaderBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="22" Margin="0,0,0,16" Effect="{StaticResource CardShadowEffect}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Mini Label Studio" FontSize="28" FontWeight="Black" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock Text="Design and print compact jewellery, stone, job or material labels for DYMO and other Windows label printers." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,5,0,0" />
                </StackPanel>
                <Border Grid.Column="1" Background="#172033" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="18" Padding="16,10" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Windows Print Ready" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
                <StackPanel>
                    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="1. Label Content" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock Text="Keep text short so it prints cleanly on small jewellery tags." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,5,0,14" />

                            <TextBlock Text="TITLE" Style="{StaticResource PillTextStyle}" />
                            <TextBox x:Name="TitleBox" TextChanged="Input_Changed" Margin="0,6,0,10" />
                            <TextBlock Text="SCAN CODE" Style="{StaticResource PillTextStyle}" />
                            <TextBox x:Name="CodeBox" TextChanged="Input_Changed" Margin="0,6,0,10" />
                            <TextBlock Text="PRICE / VALUE" Style="{StaticResource PillTextStyle}" />
                            <TextBox x:Name="PriceBox" TextChanged="Input_Changed" Margin="0,6,0,10" />
                            <TextBlock Text="DETAIL LINE 1" Style="{StaticResource PillTextStyle}" />
                            <TextBox x:Name="Line1Box" TextChanged="Input_Changed" Margin="0,6,0,10" />
                            <TextBlock Text="DETAIL LINE 2" Style="{StaticResource PillTextStyle}" />
                            <TextBox x:Name="Line2Box" TextChanged="Input_Changed" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="18" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="2. Label Format" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock Text="Choose the closest physical label size. The preview updates instantly." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,5,0,14" />
                            <ComboBox x:Name="SizeBox" SelectionChanged="Input_Changed" Tag="Choose label size">
                                <ComboBoxItem Content="Small Tag - 57 x 32 mm" IsSelected="True" />
                                <ComboBoxItem Content="Jewellery Tag - 36 x 17 mm" />
                                <ComboBoxItem Content="Address Label - 89 x 28 mm" />
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="18">
                        <StackPanel>
                            <TextBlock Text="3. Print or Save" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryTextBrush}" />
                            <TextBlock Text="Use direct printing for your DYMO label printer, or save HTML for browser printing and troubleshooting." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,5,0,14" />
                            <Button Content="Print Mini Label" Click="Print_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button Content="Save Printable HTML" Click="SaveHtml_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,8,0,0" />
                            <Border Background="#111827" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,14,0,0">
                                <TextBlock Text="Tip: choose your DYMO printer and the matching label size in the Windows print dialog. If sizing is off, save HTML and adjust printer scaling to 100%." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="22" Effect="{StaticResource CardShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Live Label Preview" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="This preview uses the same barcode bars that are sent to print." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="#111827" CornerRadius="16" Padding="14,8" VerticalAlignment="Center">
                            <TextBlock Text="Code 39" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,14">
                        <Border Background="#050914" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="24">
                            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Border x:Name="LabelPreview" Width="380" Height="215" Background="White" BorderBrush="#111827" BorderThickness="1.5" Padding="17" CornerRadius="4">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="4" Opacity="0.2" />
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock x:Name="PreviewTitle" Foreground="#111827" FontSize="26" FontWeight="Black" TextAlignment="Center" TextWrapping="Wrap" />
                                        <TextBlock x:Name="PreviewCode" Foreground="#374151" FontSize="15" TextAlignment="Center" Margin="0,4,0,4" />
                                        <TextBlock x:Name="PreviewPrice" Foreground="#111827" FontSize="22" FontWeight="Black" TextAlignment="Center" />
                                        <Border Background="#EFEAE0" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="3" Padding="4" Margin="0,10,0,4">
                                            <StackPanel x:Name="BarcodePanel" Orientation="Horizontal" Height="48" HorizontalAlignment="Center" />
                                        </Border>
                                        <TextBlock x:Name="PreviewLine1" Foreground="#111827" FontSize="14" TextAlignment="Center" />
                                        <TextBlock x:Name="PreviewLine2" Foreground="#4B5563" FontSize="12" TextAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Viewbox>
                        </Border>
                    </Grid>

                    <Border Grid.Row="2" Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Best For" Style="{StaticResource PillTextStyle}" />
                                <TextBlock Text="Stock tags" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Print Mode" Style="{StaticResource PillTextStyle}" />
                                <TextBlock Text="Windows dialog" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Fallback" Style="{StaticResource PillTextStyle}" />
                                <TextBlock Text="HTML label" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
