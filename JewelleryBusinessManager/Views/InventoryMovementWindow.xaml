<Window x:Class="JewelleryBusinessManager.Views.InventoryMovementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stock Movement" Height="620" Width="760" WindowStartupLocation="CenterOwner">
    <DockPanel Background="{StaticResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Top" Padding="10" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Stock Movement" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
            </StackPanel>
        </Border>
        <ScrollViewer Padding="12">
            <StackPanel>
                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="Material" FontWeight="SemiBold" FontSize="16" />
                        <ComboBox x:Name="MaterialBox" DisplayMemberPath="Display" SelectedValuePath="Id" Margin="0,8,0,4" SelectionChanged="MaterialBox_SelectionChanged" Tag="Choose a material" />
                        <TextBlock x:Name="MaterialInfoText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Movement Type" FontWeight="SemiBold" />
                            <ComboBox x:Name="MovementTypeBox" Margin="0,6,0,12" Tag="Choose movement type">
                                <ComboBoxItem Content="Use / consume material" IsSelected="True" />
                                <ComboBoxItem Content="Receive new stock" />
                                <ComboBoxItem Content="Adjustment / correction" />
                                <ComboBoxItem Content="Return unused stock" />
                            </ComboBox>
                            <TextBlock Text="Quantity" FontWeight="SemiBold" />
                            <TextBox x:Name="QuantityBox" Margin="0,6,0,4" />
                            <TextBlock Text="Enter a positive number. The app will make it negative for consumed material." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Reason" FontWeight="SemiBold" />
                            <TextBox x:Name="ReasonBox" Margin="0,6,0,12" Text="Material movement" />
                            <TextBlock Text="Notes" FontWeight="SemiBold" />
                            <TextBox x:Name="NotesBox" Margin="0,6,0,0" MinHeight="70" AcceptsReturn="True" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Link to Job (optional)" FontWeight="SemiBold" />
                            <ComboBox x:Name="JobBox" DisplayMemberPath="Display" SelectedValuePath="Id" Margin="0,6,0,0" Tag="Choose a linked job" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Link to Jewellery Item (optional)" FontWeight="SemiBold" />
                            <ComboBox x:Name="JewelleryBox" DisplayMemberPath="Display" SelectedValuePath="Id" Margin="0,6,0,0" Tag="Choose linked stock" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" Padding="9" Margin="0,0,0,8">
                    <TextBlock Text="Best practice: record every receive/use/adjustment as soon as it happens. This keeps material quantities, job costing and traceability reliable." Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Save Movement" Click="Save_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource ToolbarButtonStyle}" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
