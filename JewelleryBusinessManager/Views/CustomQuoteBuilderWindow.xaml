<Window x:Class="JewelleryBusinessManager.Views.CustomQuoteBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OPALNOVA — Custom Quote &amp; Proposal" Height="860" Width="1320" MinHeight="720" MinWidth="1080"
        WindowStartupLocation="CenterOwner" Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="18" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="Custom Quote &amp; Proposal Workflow" FontSize="24" FontWeight="Bold"/><TextBlock Text="Build several design options, compare live totals, create a proposal, then convert the accepted option into a production job." Foreground="{StaticResource MutedTextBrush}" Margin="0,5,0,0"/></StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="New Quote" Click="NewQuote_Click" Style="{StaticResource ToolbarButtonStyle}"/><Button Content="Save" Click="Save_Click" Style="{StaticResource AccentButtonStyle}"/><Button Content="Preview Proposal" Click="Preview_Click" Style="{StaticResource AccentButtonStyle}"/></StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="360"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,10"><StackPanel>
                        <TextBlock Text="Quote details" FontSize="17" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Existing quote"/><ComboBox x:Name="QuoteCombo" SelectionChanged="QuoteCombo_SelectionChanged" Margin="0,4,0,8"/>
                        <TextBlock Text="Customer"/><ComboBox x:Name="CustomerCombo" Margin="0,4,0,8"/>
                        <TextBlock Text="Quote code"/><TextBox x:Name="QuoteCodeBox" Margin="0,4,0,8"/>
                        <TextBlock Text="Title / project"/><TextBox x:Name="TitleBox" Margin="0,4,0,8"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Valid until"/><DatePicker x:Name="ValidUntilPicker" Margin="0,4,0,8"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="Deposit %"/><TextBox x:Name="DepositPercentBox" Margin="0,4,0,8" TextChanged="CostField_TextChanged"/></StackPanel>
                        </Grid>
                        <TextBlock Text="Introduction"/><TextBox x:Name="IntroductionBox" Height="76" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,4,0,8"/>
                        <TextBlock Text="Customer notes / requirements"/><TextBox x:Name="CustomerNotesBox" Height="70" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,4,0,8"/>
                    </StackPanel></Border>
                    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14"><StackPanel>
                        <TextBlock Text="Design options" FontSize="17" FontWeight="Bold"/>
                        <TextBlock Text="Use options for different metals, stones, designs or price levels." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,3,0,8"/>
                        <ListBox x:Name="OptionsList" Height="200" SelectionChanged="OptionsList_SelectionChanged" DisplayMemberPath="OptionName"/>
                        <UniformGrid Columns="3" Margin="0,8,0,0"><Button Content="Add" Click="AddOption_Click" Style="{StaticResource AccentButtonStyle}"/><Button Content="Duplicate" Click="DuplicateOption_Click" Style="{StaticResource ToolbarButtonStyle}"/><Button Content="Remove" Click="RemoveOption_Click" Style="{StaticResource ToolbarButtonStyle}"/></UniformGrid>
                    </StackPanel></Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"><StackPanel>
                <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,10"><StackPanel>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="Selected option" FontSize="18" FontWeight="Bold"/><CheckBox x:Name="RecommendedCheck" Grid.Column="1" Content="Recommended" Checked="CostField_TextChanged" Unchecked="CostField_TextChanged"/></Grid>
                    <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="Option name"/><TextBox x:Name="OptionNameBox" Margin="0,4,0,8" TextChanged="OptionText_TextChanged"/><TextBlock Text="Metal details"/><TextBox x:Name="MetalDetailsBox" Height="58" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,4,0,8" TextChanged="OptionText_TextChanged"/></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="Description"/><TextBox x:Name="DescriptionBox" Height="58" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,4,0,8" TextChanged="OptionText_TextChanged"/><TextBlock Text="Stone details"/><TextBox x:Name="StoneDetailsBox" Height="58" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,4,0,8" TextChanged="OptionText_TextChanged"/></StackPanel>
                    </Grid>
                </StackPanel></Border>

                <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,10"><StackPanel>
                    <TextBlock Text="Cost build-up" FontSize="18" FontWeight="Bold"/>
                    <UniformGrid Columns="4" Margin="0,10,0,0">
                        <StackPanel Margin="0,0,8,8"><TextBlock Text="Labour hours"/><TextBox x:Name="LabourHoursBox" TextChanged="CostField_TextChanged"/></StackPanel>
                        <StackPanel Margin="0,0,8,8"><TextBlock Text="Labour rate"/><TextBox x:Name="LabourRateBox" TextChanged="CostField_TextChanged"/></StackPanel>
                        <StackPanel Margin="0,0,8,8"><TextBlock Text="Metal cost"/><TextBox x:Name="MetalCostBox" TextChanged="CostField_TextChanged"/></StackPanel>
                        <StackPanel Margin="0,0,0,8"><TextBlock Text="Stone cost"/><TextBox x:Name="StoneCostBox" TextChanged="CostField_TextChanged"/></StackPanel>
                        <StackPanel Margin="0,0,8,8"><TextBlock Text="Setting cost"/><TextBox x:Name="SettingCostBox" TextChanged="CostField_TextChanged"/></StackPanel>
                        <StackPanel Margin="0,0,8,8"><TextBlock Text="Findings cost"/><TextBox x:Name="FindingsCostBox" TextChanged="CostField_TextChanged"/></StackPanel>
                        <StackPanel Margin="0,0,8,8"><TextBlock Text="Other cost"/><TextBox x:Name="OtherCostBox" TextChanged="CostField_TextChanged"/></StackPanel>
                        <StackPanel Margin="0,0,0,8"><TextBlock Text="Markup %"/><TextBox x:Name="MarkupBox" TextChanged="CostField_TextChanged"/></StackPanel>
                    </UniformGrid>
                    <Border Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,4,0,0"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Live option total" Foreground="{StaticResource MutedTextBrush}"/><TextBlock x:Name="CostBreakdownText" TextWrapping="Wrap" Margin="0,4,20,0"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="Customer price" Foreground="{StaticResource MutedTextBrush}" HorizontalAlignment="Right"/><TextBlock x:Name="TotalPriceText" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Right"/><TextBlock x:Name="DepositText" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Right"/></StackPanel></Grid></Border>
                </StackPanel></Border>


                <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,10"><StackPanel>
                    <TextBlock Text="Linked inventory &amp; reservations" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Attach actual stones and materials to this option. Costs flow into the live quote total; accepted options reserve stock without deducting it." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Unique stones" FontWeight="SemiBold"/>
                            <ComboBox x:Name="StoneCombo" Margin="0,5,0,6" SelectionChanged="StoneCombo_SelectionChanged"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Stone cost"/><TextBox x:Name="LinkedStoneCostBox" Margin="0,4,0,6"/></StackPanel>
                                <Button Grid.Column="2" Content="Link Stone" Click="LinkStone_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                            </Grid>
                            <ListBox x:Name="LinkedStonesList" Height="112" Margin="0,2,0,6"/>
                            <Button Content="Remove Selected Stone" Click="RemoveLinkedStone_Click" Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Materials" FontWeight="SemiBold"/>
                            <ComboBox x:Name="MaterialCombo" Margin="0,5,0,6" SelectionChanged="MaterialCombo_SelectionChanged"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel><TextBlock Text="Quantity"/><TextBox x:Name="MaterialQuantityBox" Text="1" Margin="0,4,0,6"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Unit cost"/><TextBox x:Name="MaterialUnitCostBox" Margin="0,4,0,6"/></StackPanel>
                                <Button Grid.Column="4" Content="Link Material" Click="LinkMaterial_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                            </Grid>
                            <TextBlock x:Name="MaterialAvailabilityText" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,5"/>
                            <ListBox x:Name="LinkedMaterialsList" Height="90" Margin="0,2,0,6"/>
                            <Button Content="Remove Selected Material" Click="RemoveLinkedMaterial_Click" Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="ReservationSummaryText" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </StackPanel></Border>
                <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="16" Margin="0,0,0,10"><StackPanel>
                    <TextBlock Text="External supplier diamonds" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Link saved Nivoda / external supplier diamonds to this quote option. Supplier cost is added to stone cost and marked up through the option total." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="120"/><ColumnDefinition Width="10"/><ColumnDefinition Width="170"/><ColumnDefinition Width="10"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="Saved external diamond"/><ComboBox x:Name="ExternalDiamondCombo" Margin="0,4,0,6" SelectionChanged="ExternalDiamondCombo_SelectionChanged"/></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="Supplier cost"/><TextBox x:Name="ExternalDiamondSupplierCostBox" Margin="0,4,0,6"/></StackPanel>
                        <StackPanel Grid.Column="4"><TextBlock Text="Status"/><ComboBox x:Name="ExternalDiamondStatusCombo" Margin="0,4,0,6"/></StackPanel>
                        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,6"><Button Content="Link External Diamond" Click="LinkExternalDiamond_Click" Style="{StaticResource AccentButtonStyle}"/><Button Content="Update Status" Click="UpdateExternalDiamondStatus_Click" Style="{StaticResource ToolbarButtonStyle}"/></StackPanel>
                    </Grid>
                    <TextBlock x:Name="ExternalDiamondSummaryText" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,2,0,6"/>
                    <ListBox x:Name="LinkedExternalDiamondsList" Height="105" Margin="0,2,0,6"/>
                    <Button Content="Remove Selected External Diamond" Click="RemoveExternalDiamond_Click" Style="{StaticResource ToolbarButtonStyle}" HorizontalAlignment="Left"/>
                </StackPanel></Border>
                <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="16"><StackPanel>
                    <TextBlock Text="Approval &amp; production" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Choose the accepted option. OPALNOVA will preserve its quoted price and create or update the linked production job." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,10"/>
                    <StackPanel Orientation="Horizontal"><Button Content="Accept &amp; Reserve Selected Option" Click="AcceptOption_Click" Style="{StaticResource AccentButtonStyle}"/><Button Content="Release Reservations" Click="ReleaseReservations_Click" Style="{StaticResource ToolbarButtonStyle}"/><Button Content="Create / Update Production Job" Click="CreateJob_Click" Style="{StaticResource AccentButtonStyle}"/><TextBlock x:Name="WorkflowStatusText" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="{StaticResource SecondaryTextBrush}"/></StackPanel>
                </StackPanel></Border>
            </StackPanel></ScrollViewer>
        </Grid>
        <TextBlock Grid.Row="2" Text="Connected workflow: quote options can now include owned stones, reserved materials and saved external supplier diamonds before proposal, acceptance and production." Foreground="{StaticResource MutedTextBrush}" Margin="4,10,0,0"/>
    </Grid>
</Window>
