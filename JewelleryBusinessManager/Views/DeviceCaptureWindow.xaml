<Window x:Class="JewelleryBusinessManager.Views.DeviceCaptureWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Camera &amp; Scale Capture Studio" Height="820" Width="1240" WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}" UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource TopHeaderBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="22" Margin="0,0,0,16" Effect="{StaticResource CardShadowEffect}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Camera &amp; Scale Capture Studio" FontSize="28" FontWeight="Black" Foreground="{StaticResource PrimaryTextBrush}" />
                    <TextBlock x:Name="SelectedRecordText" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="0,5,0,0" />
                </StackPanel>
                <Border Grid.Column="1" Background="#172033" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="18" Padding="16,10" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource WarningBrush}" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="Manual fallback always available" Foreground="{StaticResource SecondaryTextBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="455" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
                <StackPanel>
                    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="18" Margin="0,0,0,14" Effect="{StaticResource CardShadowEffect}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="1. Precision Scale" FontSize="22" FontWeight="Bold" />
                                    <TextBlock Text="Read a COM scale or type/paste a keyboard-wedge reading." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="#111827" CornerRadius="14" Padding="10,6" VerticalAlignment="Top">
                                    <TextBlock Text="WEIGHT" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="11" />
                                </Border>
                            </Grid>

                            <TextBlock Text="CONNECTION" Style="{StaticResource PillTextStyle}" />
                            <Grid Margin="0,8,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <ComboBox x:Name="PortBox" />
                                <Button Grid.Column="1" Content="Refresh" Click="RefreshPorts_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="8,0,0,0" />
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="BAUD" Style="{StaticResource PillTextStyle}" />
                                    <ComboBox x:Name="BaudBox" Margin="0,6,0,0">
                                        <ComboBoxItem Content="9600" IsSelected="True" />
                                        <ComboBoxItem Content="2400" />
                                        <ComboBoxItem Content="4800" />
                                        <ComboBoxItem Content="19200" />
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="UNIT" Style="{StaticResource PillTextStyle}" />
                                    <ComboBox x:Name="UnitBox" Margin="0,6,0,0">
                                        <ComboBoxItem Content="grams" IsSelected="True" />
                                        <ComboBoxItem Content="carats" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,14">
                                <Button Content="Connect Scale" Click="ConnectScale_Click" Style="{StaticResource AccentButtonStyle}" />
                                <Button Content="Disconnect" Click="DisconnectScale_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="8,0,0,0" />
                            </StackPanel>

                            <Border Background="#050914" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="CURRENT READING" Style="{StaticResource PillTextStyle}" />
                                    <TextBox x:Name="WeightBox" FontSize="34" FontWeight="Black" Text="0.000" TextAlignment="Center" Margin="0,8,0,8" />
                                    <Button Content="Apply Weight To Selected Record" Click="ApplyWeight_Click" Style="{StaticResource AccentButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,14,0,0">
                                <TextBlock x:Name="ScaleStatusText" Text="Scale not connected. Keyboard-wedge scales can type directly into the reading box." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="18" Effect="{StaticResource CardShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="2. USB Camera / Photo" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="Capture or import photos, then attach them directly to the selected business record." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,14" />
                            <Button Content="Open Windows Camera" Click="OpenCamera_Click" Style="{StaticResource AccentButtonStyle}" />
                            <Button Content="Import Photo File" Click="ImportPhoto_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,8,0,0" />
                            <Button Content="Import Latest Camera Roll Photo" Click="ImportLatestCameraRoll_Click" Style="{StaticResource ToolbarButtonStyle}" Margin="0,8,0,0" />
                            <Border Background="#111827" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,14,0,0">
                                <TextBlock Text="Recommended workflow: open Camera → capture image → return here → import latest Camera Roll photo." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="1" Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="22" Effect="{StaticResource CardShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Capture Preview" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="Check framing, focus and linked record status before saving photos or weights." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="#111827" CornerRadius="16" Padding="14,8" VerticalAlignment="Center">
                            <TextBlock Text="PHOTO + WEIGHT" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1" Background="#050914" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="22" Padding="16" Margin="0,16,0,14">
                        <Grid>
                            <Image x:Name="PreviewImage" Stretch="Uniform" />
                            <StackPanel x:Name="NoImageText" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="No photo imported yet" Foreground="{StaticResource SecondaryTextBrush}" FontSize="24" FontWeight="SemiBold" TextAlignment="Center" />
                                <TextBlock Text="Use the camera/import tools on the left to attach a photo." Foreground="{StaticResource MutedTextBrush}" TextAlignment="Center" Margin="0,8,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock x:Name="StatusText" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="Ready" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" Margin="14,0,0,0" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
