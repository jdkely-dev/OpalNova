<Window x:Class="JewelleryBusinessManager.Views.TraceabilityWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Traceability" Height="720" Width="920" WindowStartupLocation="CenterOwner">
    <DockPanel Background="{StaticResource AppBackgroundBrush}">
        <Border DockPanel.Dock="Top" Padding="16" Background="#0B1220" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Traceability" FontSize="23" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                <TextBlock Text="Review linked customers, jobs, stones, stock movements, markets, sales and payments for the selected record." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        <TextBox x:Name="TraceTextBox" Margin="16" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="16">
            <Button Content="Close" Click="Close_Click" Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </DockPanel>
</Window>
