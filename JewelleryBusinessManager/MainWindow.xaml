                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Production Batches"><StackPanel><TextBlock Text="Active Batches" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="ActiveBatchesText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="collections in progress" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Production Batches"><StackPanel><TextBlock Text="Batch Retail Value" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="BatchRetailValueText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="planned collection value" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Production Batches"><StackPanel><TextBlock Text="Batch Progress" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="BatchProgressText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="average active" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Opal Parcels"><StackPanel><TextBlock Text="Opal Yield" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="OpalYieldText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="finished ct / rough ct" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Opal Parcels"><StackPanel><TextBlock Text="Parcel Profit Est." Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="ParcelProfitText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="estimated stone value - parcel cost" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
