                            </StackPanel>
                        </ScrollViewer>

                        <Grid x:Name="RecordWorkspacePanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="430" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="10" Effect="{StaticResource CardShadowEffect}">
                                <Grid>
                                    <DataGrid x:Name="RecordsGrid" SelectionChanged="RecordsGrid_SelectionChanged" SelectionMode="Extended" SelectionUnit="FullRow" />
                                    <Border x:Name="RecordEmptyStatePanel" Visibility="Collapsed" Background="#0E1626" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="28" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520">
                                        <StackPanel>
                                            <TextBlock Text="No records to show" FontSize="26" FontWeight="Bold" TextAlignment="Center" />
                                            <TextBlock x:Name="RecordEmptyStateText" Text="Add your first record or clear the search box." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" />
                                            <Button Content="＋ Add Record" Click="Add_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Center" Margin="0,16,0,0" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="18" Effect="{StaticResource CardShadowEffect}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <Border Background="{StaticResource AccentGradientBrush}" CornerRadius="18" Padding="16" Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock x:Name="DetailTypeText" Text="Record Preview" Foreground="#111827" FontSize="12" FontWeight="Bold" />
                                                <TextBlock x:Name="DetailTitleText" Text="Select a record" Foreground="#111827" FontSize="25" FontWeight="Bold" TextWrapping="Wrap" Margin="0,3,0,0" />
                                                <TextBlock x:Name="DetailStatusText" Text="Key details and linked records appear here." Foreground="#1F2937" FontSize="13" TextWrapping="Wrap" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Border>

                                        <WrapPanel x:Name="DetailSummaryPanel" Margin="0,0,0,10" />

                                        <Border Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="10" Margin="0,0,0,14">
                                            <Grid>
                                                <Image x:Name="DetailPhotoImage" Height="180" Stretch="UniformToFill" Visibility="Collapsed" ClipToBounds="True" />
                                                <StackPanel x:Name="DetailPhotoEmptyPanel" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="No preview photo" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Use Add Photo to attach images to this record." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,6,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="Quick Actions" FontSize="15" FontWeight="Bold" Margin="0,0,0,6" />
                                        <WrapPanel Margin="0,0,0,14">
                                            <Button Content="✎ Edit" Click="Edit_Click" Style="{StaticResource AccentButtonStyle}" ToolTip="Edit this selected record" />
                                            <Button Content="＋ Photo" Click="AddPhoto_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Attach a photo to this record" />
                                            <Button Content="Trace" Click="TraceSelected_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open traceability for the selected record" />
                                            <Button Content="Label" Click="GenerateSelectedScanLabel_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Generate a barcode label for this record" />
                                        </WrapPanel>

                                        <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Key Details" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                                <StackPanel x:Name="DetailFieldsStack" />
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="Linked Records" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                                <StackPanel x:Name="DetailLinksStack" />
                                            </StackPanel>
                                        </Border>

                                        <Border Background="{StaticResource CardBackgroundBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="14" Padding="12">
                                            <StackPanel>
                                                <TextBlock Text="Recent Activity" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                                <StackPanel x:Name="DetailActivityStack" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>

                        <Grid x:Name="ToolWorkspacePanel" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="18" Effect="{StaticResource CardShadowEffect}">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                        <TextBlock x:Name="ToolPageTitleText" Text="Tool Workspace" FontSize="24" FontWeight="Bold" />
                                        <TextBlock x:Name="ToolPageSubtitleText" Text="Choose an action below." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="ToolActionList" />
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="2" Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Padding="18" Effect="{StaticResource CardShadowEffect}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0" Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock x:Name="ToolPreviewTitleText" Text="Preview" FontSize="22" FontWeight="Bold" />
                                            <TextBlock x:Name="ToolPreviewHintText" Text="Generated reports and documents appear here first. Use Open HTML / Print for easy printing." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button x:Name="ToolSetupTabButton" Content="Setup / Inputs" Click="ToolSetupTab_Click" Style="{StaticResource AccentButtonStyle}" ToolTip="Show the setup page for choosing inputs, dropdowns and actions" />
                                            <Button x:Name="ToolPreviewTabButton" Content="Preview / Result" Click="ToolPreviewTab_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Show the generated report, document, label or result preview" />
                                            <Border Width="1" Height="26" Background="{StaticResource BorderBrushStrong}" Margin="8,0" />
                                            <Button Content="🖨 Open HTML / Print" Click="OpenReportHtml_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open this output in your browser for printing" />
                                            <Button Content="Folder" Click="OpenReportFolder_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open the saved output folder" />
                                        </StackPanel>
                                    </Grid>
                                    <Border Grid.Row="1" Background="{StaticResource CardAltBackgroundBrush}" BorderBrush="{StaticResource BorderBrushStrong}" BorderThickness="1" CornerRadius="14">
                                        <Grid x:Name="ToolPreviewHost">
                                            <WebBrowser x:Name="ToolPreviewBrowser" Visibility="Collapsed" />
                                            <ScrollViewer x:Name="ToolInputScrollViewer" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                                                <StackPanel x:Name="ToolInputPanel" Margin="18" />
                                            </ScrollViewer>
                                            <StackPanel x:Name="ToolPreviewEmptyPanel" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520">
                                                <TextBlock Text="No preview generated yet" Foreground="{StaticResource PrimaryTextBrush}" FontSize="24" FontWeight="SemiBold" TextAlignment="Center" />
                                                <TextBlock Text="Use Setup / Inputs to choose dropdowns, selected records and action settings. Generated reports, labels and documents will appear here in Preview / Result." Foreground="{StaticResource MutedTextBrush}" FontSize="14" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <Grid x:Name="ReportPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{StaticResource CardGradientBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,12" Effect="{StaticResource CardShadowEffect}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock x:Name="ReportTitleText" Text="Report Viewer" FontSize="26" FontWeight="Bold" />
                                        <TextBlock x:Name="ReportPathText" Text="Generated reports open here. Use Open HTML / Print for browser printing." Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="← Back" Click="CloseReport_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Return to the active section" />
                                        <Button Content="🖨 Open HTML / Print" Click="OpenReportHtml_Click" Style="{StaticResource AccentButtonStyle}" ToolTip="Open the generated HTML file in your default browser for printing. Shortcut: Ctrl+P" />
                                        <Button Content="Folder" Click="OpenReportFolder_Click" Style="{StaticResource ToolbarButtonStyle}" ToolTip="Open the folder containing this report" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Row="1" Background="{StaticResource AppBackgroundBrush}" BorderBrush="#000000" BorderThickness="3" CornerRadius="14" Padding="0">
                                <WebBrowser x:Name="ReportBrowser" />
                            </Border>
                        </Grid>


                        <TabControl x:Name="WorkspaceTabs" Visibility="Collapsed" Panel.ZIndex="40" Background="{StaticResource PanelBackgroundBrush}" BorderBrush="#000000" BorderThickness="3" Padding="0" SelectionChanged="WorkspaceTabs_SelectionChanged">
                            <TabControl.Resources>
                                <Style TargetType="TabItem" BasedOn="{StaticResource OpalnovaWorkspaceTabItemStyle}" />
                            </TabControl.Resources>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
