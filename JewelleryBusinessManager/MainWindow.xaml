                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Market Events"><StackPanel><TextBlock Text="Upcoming Markets" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="UpcomingMarketsText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="events from today forward" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Market Stock"><StackPanel><TextBlock Text="Market Stock" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="MarketStockCountText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="items assigned to markets" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Market Studio"><StackPanel><TextBlock Text="Packed" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="MarketPackedText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="market stock checked off" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Market Studio"><StackPanel><TextBlock Text="Market Net Est." Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="MarketNetText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="takings minus event costs" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                    </UniformGrid>
                                </Expander>

                                <Expander Header="Supplier Purchasing" IsExpanded="True" Margin="0,0,0,10">
                                    <UniformGrid Columns="4" Margin="0,8,0,0">
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Purchase Orders"><StackPanel><TextBlock Text="Open Purchase Orders" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="OpenPurchaseOrdersText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="draft, ordered or partially received" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Purchase Orders"><StackPanel><TextBlock Text="Expected Soon" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="PurchaseOrdersDueText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="orders due in the next 14 days" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Purchasing Studio"><StackPanel><TextBlock Text="Reorder Suggestions" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="ReorderSuggestionsText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="materials below reorder level" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Purchase Orders"><StackPanel><TextBlock Text="Open PO Value" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="SupplierOrderValueText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="estimated open supplier spend" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                    </UniformGrid>
                                </Expander>

                                <Expander Header="Online Selling" IsExpanded="False" Margin="0,0,0,10">
                                    <UniformGrid Columns="3" Margin="0,8,0,0">
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Online Listings"><StackPanel><TextBlock Text="Needs Listing" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="NeedsListingText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="stock without listing" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Online Listings"><StackPanel><TextBlock Text="Ready To List" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="ReadyToListText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="content/photos checked" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
                                        <Border Style="{StaticResource DashboardTileStyle}" MouseLeftButtonUp="DashboardTile_Click" Tag="Online Listings"><StackPanel><TextBlock Text="Listed Online" Style="{StaticResource DashboardTileLabelStyle}"/><TextBlock x:Name="ListedOnlineText" Style="{StaticResource DashboardTileValueStyle}"/><TextBlock Text="active listing records" Style="{StaticResource DashboardTileHintStyle}"/></StackPanel></Border>
